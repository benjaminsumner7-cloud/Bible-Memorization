function doRandom() {
  const modes = ['fill', 'bank', 'quiz'];
  const diffs = ['easy', 'medium', 'hard'];
  state.mode = modes[Math.floor(Math.random() * modes.length)];
  state.difficulty = diffs[Math.floor(Math.random() * diffs.length)];
  state.verse = BIBLE_VERSES[Math.floor(Math.random() * BIBLE_VERSES.length)];
  
  document.querySelectorAll('.mode-card').forEach(c => c.classList.remove('selected'));
  document.querySelector(`.mode-card[data-mode="${state.mode}"]`)?.classList.add('selected');
  
  toast(`Random: ${state.mode.toUpperCase()} | ${state.difficulty.toUpperCase()} | ${state.verse.ref}`, 'info');
  showScreen(state.mode + '-screen');
  startStudy(state.mode);
}

function handleRandom() {
  if(state.inGame && !state.completed) {
    state.pendingNavigation = 'random';
    $('cancel-modal').classList.add('active');
    return;
  }
  doRandom();
}

