function selectBlanks(words,count) {
  const avail=words.map((w,i)=>({word:w.toLowerCase(),i})).filter(x=>!SKIP_WORDS.has(x.word)&&x.word.length>2).map(x=>x.i);
  if(avail.length<count) return shuffle([...Array(words.length).keys()]).slice(0,count);
  return shuffle(avail).slice(0,count);
}

function genRounds(mode,diff,wc) {
  let rounds=[];
  const cfg = { easy:{startMin:1, startMax:2, addMin:1, addMax:2}, medium:{startMin:2, startMax:4, addMin:2, addMax:4}, hard:{startMin:3, startMax:6, addMin:3, addMax:6} };
  const c = cfg[diff];
  const start = c.startMin + Math.floor(Math.random() * (c.startMax - c.startMin + 1));
  const add = c.addMin + Math.floor(Math.random() * (c.addMax - c.addMin + 1));
  const totalRounds = Math.min(10, Math.max(4, Math.floor(wc / 2)));
  let cur = Math.min(start, wc - 1);
  for(let i = 0; i < totalRounds && cur < wc; i++) { rounds.push(cur); cur = Math.min(cur + add, wc - 1); }
  rounds.push(wc);
  return rounds;
}

function renderVerseList(mode) {
  const el=$(mode+'-verse-list'); if(!el)return; el.innerHTML='';
