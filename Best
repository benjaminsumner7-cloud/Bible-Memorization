<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Scripture Strong | Bible Memorization</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
<style>
:root {
  --primary: #0284c7; --primary-dark: #0369a1; --gold: #D4AF37; --gold-light: #E6C06B;
  --success: #16a34a; --error: #ef4444; --warning: #f59e0b; --dark: #0f172a; --gray: #475569;
  --light-gray: #94a3b8; --border: #e2e8f0; --surface: #f8fafc; --white: #ffffff;
  --shadow: 0 4px 20px rgba(0,0,0,0.08); --shadow-lg: 0 12px 40px rgba(0,0,0,0.12);
  --radius: 16px; --radius-lg: 24px; --transition: all 0.25s ease;
  --memorized-bg: linear-gradient(135deg, #dcfce7, #bbf7d0); --memorized-border: #16a34a; --memorized-text: #15803d;
}
* { margin: 0; padding: 0; box-sizing: border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'Inter', sans-serif; background: linear-gradient(135deg, #f8fafc 0%, #eef2f7 100%); color: var(--dark); line-height: 1.6; min-height: 100vh; }
.nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; background: rgba(255,255,255,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); height: 72px; display: flex; align-items: center; justify-content: space-between; padding: 0 2rem; transition: box-shadow 0.3s ease; }
.nav.scrolled { box-shadow: var(--shadow); }
.logo { font-family: 'Playfair Display', serif; font-weight: 800; font-size: 1.75rem; background: linear-gradient(135deg, var(--gold), var(--primary)); -webkit-background-clip: text; background-clip: text; color: transparent; cursor: pointer; display: flex; align-items: center; gap: 8px; }
.logo i { font-size: 1.3rem; animation: float 3s ease-in-out infinite; }
@keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-4px); } }
.nav-links { display: flex; gap: 6px; align-items: center; }
.nav-link { font-weight: 600; color: var(--gray); padding: 8px 14px; border-radius: 12px; transition: var(--transition); display: flex; align-items: center; gap: 6px; font-size: 0.9rem; background: none; border: none; cursor: pointer; text-decoration: none; }
.nav-link:hover, .nav-link.active { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; transform: translateY(-1px); }
.nav-cta { background: linear-gradient(135deg, var(--gold), var(--gold-light)); color: var(--dark); font-weight: 700; padding: 10px 22px; border-radius: 14px; border: none; cursor: pointer; font-size: 0.9rem; display: flex; align-items: center; gap: 6px; transition: var(--transition); }
.nav-cta:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,175,55,0.4); }
.screen { display: none; min-height: 100vh; padding-top: 96px; padding-bottom: 3rem; }
.screen.active { display: block; animation: fadeIn 0.35s ease-out; }
@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.container { max-width: 1000px; margin: 0 auto; padding: 0 1.5rem; }
.hero { text-align: center; padding: 3rem 1rem 2rem; }
.hero-title { font-family: 'Playfair Display', serif; font-size: 4.5rem; font-weight: 800; background: linear-gradient(135deg, var(--gold), var(--primary)); -webkit-background-clip: text; background-clip: text; color: transparent; margin-bottom: 1.5rem; }
.hero-subtitle { font-size: 1.6rem; font-weight: 600; color: var(--dark); margin-bottom: 2rem; }
.hero-verse { font-family: 'Playfair Display', serif; font-size: 2rem; font-weight: 600; color: var(--primary-dark); line-height: 1.5; max-width: 650px; margin: 0 auto; padding: 2rem; background: var(--white); border-radius: var(--radius-lg); box-shadow: var(--shadow); border: 1px solid var(--border); position: relative; }
.hero-verse::before, .hero-verse::after { content: '"'; font-family: Georgia, serif; font-size: 4.5rem; color: rgba(212,175,55,0.15); position: absolute; line-height: 1; }
.hero-verse::before { top: -15px; left: -10px; }
.hero-verse::after { bottom: -40px; right: -10px; transform: rotate(180deg); }
.hero-reference { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--primary); margin-top: 1rem; }
.mode-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem; max-width: 1100px; margin: 3rem auto; padding: 0 1.5rem; }
.mode-card { background: var(--white); border-radius: var(--radius-lg); padding: 2rem; box-shadow: var(--shadow); cursor: pointer; transition: var(--transition); border: 2px solid transparent; }
.mode-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-lg); border-color: var(--border); }
.mode-card.selected { border-color: var(--gold); box-shadow: 0 0 0 2px rgba(212,175,55,0.2), var(--shadow-lg); }
.mode-icon { width: 64px; height: 64px; border-radius: 18px; display: flex; align-items: center; justify-content: center; margin: 0 auto 1.25rem; font-size: 1.6rem; }
.mode-fill .mode-icon { background: #e0f2fe; color: #0284c7; }
.mode-bank .mode-icon { background: #dcfce7; color: #16a34a; }
.mode-quiz .mode-icon { background: #ffedd5; color: #ea580c; }
.mode-title { font-family: 'Playfair Display', serif; font-size: 1.6rem; font-weight: 700; margin-bottom: 0.75rem; }
.mode-desc { color: var(--gray); font-size: 0.95rem; margin-bottom: 1.25rem; }
.mode-features { display: flex; flex-wrap: wrap; gap: 6px; }
.feature-tag { background: var(--surface); color: var(--gray); padding: 4px 12px; border-radius: 20px; font-size: 0.8rem; font-weight: 600; border: 1px solid var(--border); }
.btn { background: linear-gradient(135deg, var(--primary), var(--primary-dark)); color: white; border: none; border-radius: 14px; padding: 14px 28px; font-weight: 700; font-size: 1.05rem; cursor: pointer; transition: var(--transition); display: inline-flex; align-items: center; gap: 8px; font-family: 'Inter', sans-serif; }
.btn:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(2,132,199,0.35); }
.btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; filter: grayscale(0.5); }
.btn-secondary { background: var(--white); color: var(--primary); border: 2px solid var(--primary); }
.btn-secondary:hover { background: #f0f9ff; transform: translateY(-2px); }
.btn-large { padding: 16px 40px; font-size: 1.15rem; }
.btn-danger { background: linear-gradient(135deg, var(--error), #dc2626); }
.btn-danger:hover { box-shadow: 0 6px 20px rgba(239,68,68,0.4); }
.btn-tutorial { background: linear-gradient(135deg, #8b5cf6, #7c3aed); color: white; }
.btn-tutorial:hover { box-shadow: 0 6px 20px rgba(139,92,246,0.4); }
.section-header { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 700; margin-bottom: 1.5rem; padding-bottom: 12px; border-bottom: 2px solid var(--gold); display: inline-block; }
.verse-list { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1rem; max-height: 55vh; overflow-y: auto; margin: 1.5rem 0; padding-right: 4px; }
.verse-list::-webkit-scrollbar { width: 6px; }
.verse-list::-webkit-scrollbar-track { background: var(--surface); border-radius: 8px; }
.verse-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 8px; }
.verse-item { background: var(--white); border-radius: 14px; padding: 1.25rem; box-shadow: var(--shadow); cursor: pointer; transition: var(--transition); border: 2px solid transparent; position: relative; }
.verse-item:hover { transform: translateY(-2px); box-shadow: var(--shadow-lg); }
.verse-item.selected { border-color: var(--primary); background: #f0f9ff; }
.verse-item.memorized { background: var(--memorized-bg); border-color: var(--memorized-border); box-shadow: 0 4px 15px rgba(22, 163, 74, 0.15); }
.memorized-badge { position: absolute; top: 8px; right: 12px; background: var(--memorized-border); color: white; padding: 4px 10px; border-radius: 8px; font-size: 0.7rem; font-weight: 700; display: flex; align-items: center; gap: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
.verse-ref { font-family: 'Playfair Display', serif; font-weight: 700; color: var(--primary); margin-bottom: 4px; font-size: 1.15rem; }
.verse-item.memorized .verse-ref { color: var(--memorized-text); }
.verse-text { color: var(--dark); font-size: 0.95rem; line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; margin-bottom: 6px; }
.verse-words { font-size: 0.85rem; color: var(--light-gray); }
.memorized-info { font-size: 0.85rem; color: var(--success); font-weight: 700; margin-top: 8px; display: flex; align-items: center; gap: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
.memorized-info i { color: var(--success); }
.api-section { background: var(--white); border-radius: var(--radius); padding: 1.75rem; margin: 1.5rem 0; box-shadow: var(--shadow); border-top: 3px solid var(--gold); }
.api-input-group { display: flex; gap: 12px; margin: 1rem 0; }
.api-input { flex: 1; padding: 12px 18px; border: 2px solid var(--border); border-radius: 12px; font-size: 1rem; font-family: inherit; transition: var(--transition); }
.api-input:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(2,132,199,0.15); }
.api-result { margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px dashed var(--border); animation: fadeIn 0.4s ease-out; }
.api-verse-ref { font-family: 'Playfair Display', serif; font-weight: 700; color: var(--primary); font-size: 1.25rem; margin-bottom: 0.5rem; }
.api-verse-text { font-size: 1.15rem; color: var(--dark); line-height: 1.6; font-weight: 500; }
.difficulty-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.25rem; margin: 1.5rem 0; }
.difficulty-card { background: var(--white); border-radius: var(--radius); padding: 1.5rem; box-shadow: var(--shadow); cursor: pointer; transition: var(--transition); border: 2px solid transparent; text-align: center; }
.difficulty-card:hover, .difficulty-card.selected { transform: translateY(-3px); border-color: var(--gold); box-shadow: var(--shadow-lg); }
.difficulty-icon { font-size: 2.5rem; margin-bottom: 0.5rem; }
.difficulty-name { font-family: 'Playfair Display', serif; font-size: 1.5rem; font-weight: 700; margin: 0.5rem 0; }
.difficulty-desc { color: var(--gray); font-size: 0.95rem; margin-bottom: 1rem; min-height: 40px; }
.difficulty-details { background: var(--surface); border-radius: 12px; padding: 14px; text-align: left; }
.difficulty-details div { display: flex; justify-content: space-between; margin: 4px 0; padding: 4px 0; border-bottom: 1px dashed var(--border); }
.difficulty-details span:last-child { font-weight: 700; color: var(--primary); }
.verse-display { background: var(--white); border-radius: var(--radius-lg); padding: 2rem 2.5rem; box-shadow: var(--shadow-lg); margin: 1.25rem 0; min-height: 100px; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; font-family: 'Playfair Display', serif; letter-spacing: 0.01em; border: 1px solid var(--border); position: relative; }
.verse-content { font-size: 1.65rem; font-weight: 500; line-height: 1.75; color: var(--dark); }
.verse-ref-bottom { font-weight: 700; color: var(--primary); font-size: 1rem; margin-top: 1rem; background: rgba(2, 132, 199, 0.08); padding: 6px 14px; border-radius: 20px; text-align: center; font-family: 'Playfair Display', serif; }
.study-phase-wrapper { display: flex; flex-direction: column; align-items: center; justify-content: center; width: 100%; }
.study-verse-text { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 500; line-height: 1.85; color: var(--dark); text-align: center; letter-spacing: 0.015em; word-spacing: 0.1em; max-width: 900px; padding: 0.5rem; }
.study-word { font-family: 'Playfair Display', serif; font-size: 2.8rem; font-weight: 500; line-height: 1.85; display: inline; animation: fadeInWord 0.4s ease both; }
.study-reference-badge { margin-top: 1.5rem; font-family: 'Playfair Display', serif; font-weight: 700; color: var(--primary); font-size: 1.3rem; background: rgba(2, 132, 199, 0.08); padding: 8px 20px; border-radius: 24px; text-align: center; }
@keyframes fadeInWord { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }
@media (max-width: 1024px) { .study-verse-text, .study-word { font-size: 2.4rem; line-height: 1.8; } }
@media (max-width: 768px) { .study-verse-text, .study-word { font-size: 2.1rem; line-height: 1.75; letter-spacing: 0.01em; } .study-reference-badge { font-size: 1.15rem; padding: 6px 16px; } }
@media (max-width: 480px) { .study-verse-text, .study-word { font-size: 1.85rem; line-height: 1.7; word-spacing: 0.05em; } .study-reference-badge { font-size: 1rem; padding: 5px 14px; } .verse-display { padding: 1.5rem 1.75rem; } }
#fill-study-verse.verse-display, #bank-study-verse.verse-display, #quiz-study-verse.verse-display { padding: 2.5rem 3rem; min-height: 180px; }
.blank-container { display: inline-flex; align-items: center; vertical-align: baseline; }
.blank-input { background: rgba(2, 132, 199, 0.04); border: none; border-bottom: 3px dashed var(--primary); min-width: 70px; text-align: center; padding: 2px 6px; margin: 0 0.1em; font-family: inherit; font-size: inherit; font-weight: 600; color: var(--primary); outline: none; transition: var(--transition); border-radius: 4px 4px 0 0; line-height: 1.6; }
.blank-input:hover { background: rgba(2, 132, 199, 0.08); }
.blank-input:focus { background: rgba(2, 132, 199, 0.08); border-bottom-color: var(--primary-dark); border-bottom-width: 4px; box-shadow: 0 0 0 2px rgba(2, 132, 199, 0.15); }
.blank-input.correct { border-bottom-color: var(--success) !important; border-bottom-style: solid; color: var(--success); background: rgba(22, 163, 74, 0.06); }
.blank-input.incorrect { border-bottom-color: var(--error) !important; border-bottom-style: solid; color: var(--error); background: rgba(239, 68, 68, 0.06); }
.blank-input.filled { background: rgba(2, 132, 199, 0.06); color: var(--primary); border-bottom-color: var(--primary); border-bottom-width: 3px; }
.blank-input:disabled { background: transparent; border-bottom: 3px dashed #cbd5e1; color: #cbd5e1; cursor: not-allowed; }
@keyframes shake { 0%, 100% { transform: translateX(0); } 25% { transform: translateX(-4px); } 75% { transform: translateX(4px); } }
.word-bank { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin: 1.25rem 0; padding: 1rem; background: var(--surface); border-radius: 16px; border: 1px solid var(--border); min-height: 50px; }
.word-chip { background: var(--white); border: 2px solid var(--border); border-radius: 14px; padding: 8px 18px; font-weight: 700; cursor: grab; transition: var(--transition); box-shadow: 0 2px 8px rgba(0,0,0,0.05); user-select: none; font-size: 1rem; }
.word-chip:hover { transform: translateY(-2px); border-color: var(--primary); box-shadow: var(--shadow); }
.word-chip:active { cursor: grabbing; }
.word-chip.used { opacity: 0.5; cursor: not-allowed; transform: scale(0.95); border-style: dashed; }
.word-chip.correct { background: #dcfce7; border-color: var(--success); color: var(--success); }
.word-chip.incorrect { background: #fee2e2; border-color: var(--error); color: var(--error); }
.blank-slot { display: inline-block; min-width: 80px; border-bottom: 3px dashed var(--light-gray); margin: 0 0.15em; padding: 0 8px; text-align: center; vertical-align: baseline; min-height: 1.8em; transition: var(--transition); cursor: pointer; }
.blank-slot.filled { border-bottom-style: solid; border-bottom-color: var(--primary); font-weight: 600; color: var(--primary); }
.blank-slot.correct { border-bottom-color: var(--success); color: var(--success); }
.blank-slot.incorrect { border-bottom-color: var(--error); color: var(--error); }
.quiz-questions-wrap { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 14px; margin: 1rem 0; padding: 0; }
.question-block { background: var(--white); border-radius: 14px; padding: 16px 18px; border: 1px solid var(--border); box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
.question-title { font-weight: 700; color: var(--dark); margin-bottom: 10px; font-size: 0.95rem; display: flex; align-items: center; gap: 8px; }
.question-number { background: var(--primary); color: white; width: 28px; height: 28px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 0.8rem; flex-shrink: 0; }
.mc-options { display: grid; grid-template-columns: repeat(auto-fill, minmax(90px, 1fr)); gap: 6px; }
.mc-option { background: var(--white); border: 2px solid var(--border); border-radius: 10px; padding: 10px 8px; font-weight: 600; cursor: pointer; transition: var(--transition); text-align: center; font-size: 0.9rem; word-break: break-word; }
.mc-option:hover:not(.disabled) { border-color: var(--primary); transform: translateY(-1px); box-shadow: var(--shadow); }
.mc-option.selected { border-color: var(--primary); background: #f0f9ff; font-weight: 700; }
.mc-option.correct { background: #dcfce7; border-color: var(--success); color: var(--success); font-weight: 700; }
.mc-option.incorrect { background: #fee2e2; border-color: var(--error); color: var(--error); font-weight: 600; }
.mc-option.disabled { pointer-events: none; opacity: 0.7; }
.timer-container { text-align: center; margin: 1.5rem 0; }
.timer-circle { width: 120px; height: 120px; border-radius: 50%; margin: 0 auto 1rem; background: conic-gradient(var(--primary) 0%, var(--border) 0%); display: flex; align-items: center; justify-content: center; position: relative; box-shadow: var(--shadow); transition: background 0.3s ease; }
.timer-circle::before { content: ''; position: absolute; width: 100px; height: 100px; border-radius: 50%; background: var(--white); }
.timer-text { position: relative; z-index: 1; font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 800; color: var(--primary); }
.timer-label { font-weight: 700; font-size: 1.1rem; margin-bottom: 1.25rem; }
.study-extra-btn { background: linear-gradient(135deg, #fbbf24 0%, #d97706 100%); color: #0f172a; border: none; border-radius: 30px; padding: 12px 20px; font-weight: 700; font-size: 0.9rem; cursor: pointer; transition: all 0.3s ease; display: inline-flex; align-items: center; justify-content: center; gap: 8px; box-shadow: 0 4px 15px rgba(251, 191, 36, 0.35); position: relative; overflow: hidden; min-width: 170px; }
.study-extra-btn::after { content: ''; position: absolute; top: 0; left: -100%; width: 50%; height: 100%; background: linear-gradient(90deg, transparent, rgba(255,255,255,0.4), transparent); transform: skewX(-25deg); transition: all 0.6s; }
.study-extra-btn:hover:not(:disabled) { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(251, 191, 36, 0.5); }
.study-extra-btn:hover::after { left: 150%; transition: all 0.8s; }
.study-extra-btn:active:not(:disabled) { transform: translateY(0); }
.study-extra-btn:disabled { background: linear-gradient(135deg, #9ca3af, #6b7280); color: #f3f4f6; cursor: not-allowed; box-shadow: none; }
.study-extra-btn:disabled:hover { transform: none; }
.study-extra-badge { background: rgba(255,255,255,0.25); padding: 3px 8px; border-radius: 10px; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.03em; }
.study-extra-btn:disabled .study-extra-badge { background: rgba(0,0,0,0.2); color: #e5e7eb; }
.results-card { background: var(--white); border-radius: var(--radius-lg); padding: 2.5rem; box-shadow: var(--shadow-lg); text-align: center; max-width: 650px; margin: 2rem auto; border-top: 4px solid var(--gold); }
.results-icon { font-size: 4rem; margin-bottom: 1rem; color: var(--success); }
.results-title { font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 800; margin-bottom: 0.75rem; }
.results-stats { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1rem; margin: 1.5rem 0; }
.result-stat { background: var(--surface); border-radius: 14px; padding: 1rem; border: 1px solid var(--border); }
.result-value { font-family: 'Playfair Display', serif; font-size: 1.7rem; font-weight: 800; color: var(--primary); }
.result-label { color: var(--gray); font-weight: 600; font-size: 0.9rem; }
.game-info { display: flex; justify-content: space-between; align-items: center; padding: 10px 16px; background: var(--white); border-radius: 12px; margin-bottom: 1rem; box-shadow: var(--shadow); border: 1px solid var(--border); flex-wrap: wrap; gap: 0.5rem; }
.game-info-item { display: flex; align-items: center; gap: 6px; }
.game-info-label { font-weight: 600; color: var(--gray); font-size: 0.9rem; }
.game-info-value { font-weight: 800; color: var(--primary); font-size: 1.1rem; }
.toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 2000; }
.toast { background: var(--white); border-radius: 14px; padding: 14px 20px; box-shadow: var(--shadow-lg); display: flex; align-items: center; gap: 12px; margin-top: 10px; transform: translateX(140%); transition: transform 0.3s ease; border-left: 4px solid var(--primary); max-width: 380px; }
.toast.show { transform: translateX(0); }
.toast-success { border-left-color: var(--success); }
.toast-error { border-left-color: var(--error); }
.toast-info { border-left-color: var(--primary); }
.toast-warning { border-left-color: var(--warning); }
.toast-icon { font-size: 1.2rem; flex-shrink: 0; }
.modal-overlay { position: fixed; inset: 0; z-index: 500; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); display: none; align-items: center; justify-content: center; animation: fadeIn 0.2s ease-out; }
.modal-overlay.active { display: flex; }
.modal-content { background: var(--white); border-radius: var(--radius-lg); padding: 2.5rem; max-width: 480px; width: 90%; box-shadow: var(--shadow-lg); text-align: center; }
.modal-icon { font-size: 3rem; color: var(--error); margin-bottom: 1rem; }
.modal-title { font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 700; margin-bottom: 0.75rem; }
.modal-message { color: var(--gray); margin-bottom: 2rem; line-height: 1.6; }
