      { icon: "fa-solid fa-trophy", title: "Final Round", desc: "The last round blanks the ENTIRE verse! Master it to complete the game and earn bonus XP. 🏆" }
    ]},
  quiz: { title: "Quiz Mode Tutorial", steps: [
      { icon: "fa-solid fa-list-check", title: "Welcome!", desc: "In Quiz mode, you'll <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>select the correct word</span> from multiple-choice options for each blank." },
      { icon: "fa-solid fa-magnifying-glass", title: "Choose a Verse", desc: "Pick a verse or <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>fetch one</span> by typing a reference like 'John 3:16'." },
      { icon: "fa-solid fa-seedling", title: "Select Difficulty", desc: "<span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>Easy</span>: 4 options | <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>Medium</span>: 6 options | <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>Hard</span>: 8 options per blank." },
      { icon: "fa-solid fa-book-open", title: "Study Phase", desc: "Memorize the verse. Skip early or use <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>+20s</span> for extra time (15 XP cost)." },
      { icon: "fa-solid fa-circle-question", title: "Answer Questions", desc: "Each blank has a numbered question. <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>Click an option</span> to select it. You must answer ALL before submitting." },
      { icon: "fa-solid fa-check-double", title: "Submit All", desc: "Click <span style='display:inline-block;background:rgba(2,132,199,0.1);padding:2px 8px;border-radius:6px;font-weight:600;color:var(--primary);border:1px dashed var(--primary);'>Submit All Answers</span> to check. Correct options turn <span style='display:inline-block;background:rgba(22,163,74,0.1);padding:2px 8px;border-radius:6px;font-weight:700;color:var(--success);'>green</span>, wrong turn <span style='display:inline-block;background:rgba(239,68,68,0.1);padding:2px 8px;border-radius:6px;font-weight:700;color:var(--error);'>red</span>. Fix and retry!" },
      { icon: "fa-solid fa-trophy", title: "Complete!", desc: "Master the verse to earn XP and add it to your collection. Your accuracy and streaks boost your total score! 🎯" }
    ]}
};

let tutorialState = { mode: null, step: 0 };

function startTutorial(mode) {
  tutorialState = { mode, step: 0 };
  $('tutorial-overlay').style.display = 'flex';
  renderTutorialStep();
}

function renderTutorialStep() {
  const t = TUTORIALS[tutorialState.mode];
  const s = t.steps[tutorialState.step];
  $('tutorial-title').textContent = s.title;
  $('tutorial-desc').innerHTML = s.desc;
  $('tutorial-icon').innerHTML = `<i class="${s.icon}"></i>`;
  const prog = $('tutorial-progress'); prog.innerHTML = '';
  t.steps.forEach((_, i) => { const dot = document.createElement('div'); dot.className = 'tutorial-dot' + (i === tutorialState.step ? ' active' : ''); dot.style.cssText='width:10px;height:10px;border-radius:50%;background:'+(i===tutorialState.step?'var(--primary)':'var(--border)')+';transition:var(--transition);'+(i===tutorialState.step?'transform:scale(1.2);':''); prog.appendChild(dot); });
  $('tutorial-prev').disabled = tutorialState.step === 0;
  $('tutorial-next').innerHTML = tutorialState.step === t.steps.length - 1 ? 'Finish <i class="fa-solid fa-flag-checkered"></i>' : 'Next <i class="fa-solid fa-arrow-right"></i>';
}

function nextTutorialStep() {
  const t = TUTORIALS[tutorialState.mode];
  if (tutorialState.step < t.steps.length - 1) { tutorialState.step++; renderTutorialStep(); } 
  else { endTutorial(); toast('Tutorial complete! You\'re ready to play. 🎉', 'success'); }
}

function prevTutorialStep() {
  if (tutorialState.step > 0) { tutorialState.step--; renderTutorialStep(); }
}

function endTutorial() {
  $('tutorial-overlay').style.display = 'none';
  tutorialState = { mode: null, step: 0 };
}

// ==================== INIT ====================
function init() {
  loadState();
  document.querySelectorAll('.nav-link').forEach(l=>l.addEventListener('click',e=>{e.preventDefault();handleNavigation(l.dataset.screen);}));
  $('home-btn').addEventListener('click',()=>handleNavigation('home'));
  $('stats-back').addEventListener('click',()=>handleNavigation('home'));
  $('rules-back-to-home').addEventListener('click',()=>handleNavigation('home'));
  
  // Modal handlers
  $('cancel-stay').addEventListener('click',()=>{
    $('cancel-modal').classList.remove('active');
    state.pendingNavigation=null;
  });
  $('cancel-quit').addEventListener('click',()=>{ 
    $('cancel-modal').classList.remove('active'); 
    if(state.pendingNavigation){ 
      state.xp=0; state.wordsCorrect=0; state.wordsWrong=0; state.completed=false; 
      state.inGame = false;
      toast('Session XP forfeited.','warning'); 
      if(state.pendingNavigation === 'random') {
        doRandom();
      } else {
        doNavigation(state.pendingNavigation); 
      }
      state.pendingNavigation = null;
    } 
  });
  
  document.querySelectorAll('.mode-card').forEach(card=>card.addEventListener('click',()=>{document.querySelectorAll('.mode-card').forEach(c=>c.classList.remove('selected'));card.classList.add('selected');state.mode=card.dataset.mode;}));
  $('start-game-btn').addEventListener('click',()=>handleNavigation(state.mode));
  
  ['fill','bank','quiz'].forEach(mode=>{
    $(mode+'-back').addEventListener('click',()=>handleNavigation('home'));
    $(mode+'-back-verses').addEventListener('click',()=>{$(mode+'-difficulty-select').classList.add('hidden');$(mode+'-verse-select').classList.remove('hidden');});
    $(mode+'-start-game').addEventListener('click',()=>startStudy(mode));
    $(mode+'-skip-study').addEventListener('click',()=>skipStudy(mode));
    $(mode+'-submit-answer').addEventListener('click',()=>{if(mode==='fill')submitFill();else if(mode==='bank')submitBank();else submitQuiz();});
    $(mode+'-next-round').addEventListener('click',()=>nextRound(mode));
    $(mode+'-fetch-btn').addEventListener('click',()=>{const r=$(mode+'-api-ref').value.trim();r?fetchVerse(r,mode):toast('Enter ref','error');});
    $(mode+'-api-ref').addEventListener('keydown',e=>{if(e.key==='Enter'){const r=e.target.value.trim();r&&fetchVerse(r,mode);}});
    $(mode+'-extra-study').addEventListener('click',()=>{ if(state.extraStudyUses<=0) { toast('No extra time left!','info'); return; } if(state.xp <= EXTRA_STUDY_COST) { toast(`Need >15 XP! You have ${state.xp}.`,'error'); return; } state.extraStudyUses--; state.xp -= EXTRA_STUDY_COST; state.studySecondsInitial += 20; state.studySeconds += 20; $(mode+'-timer').textContent = state.studySeconds; updateTimerCircle(mode, state.studySeconds); updateExtraStudyBtn(mode); updateXPHighlight(mode, state.xp); toast(`-15 XP deducted! +20s added.`,'info'); });
    $(mode+'-help-btn').addEventListener('click',()=>activateHelp(mode));
  });
  
  document.querySelectorAll('.difficulty-card').forEach(c=>c.addEventListener('click',()=>{c.parentElement.querySelectorAll('.difficulty-card').forEach(x=>x.classList.remove('selected'));c.classList.add('selected');state.difficulty=c.dataset.difficulty;}));
  document.addEventListener('keydown',e=>{ if(e.key==='Enter')['fill','bank','quiz'].forEach(mode=>{if(state.inGame&&$(mode+'-results-phase')&&!$(mode+'-results-phase').classList.contains('hidden')){e.preventDefault();nextRound(mode);}}); });
  window.addEventListener('scroll',()=>{$('main-nav').classList.toggle('scrolled',window.scrollY>10);});
  $('nav-random-btn').addEventListener('click', handleRandom);
  ['fill','bank','quiz'].forEach(m=>renderVerseList(m));
  
  $('stats-reset').addEventListener('click', resetStats);
  
  // Tutorial Triggers
  $('rules-tutorial-fill').addEventListener('click', () => startTutorial('fill'));
  $('rules-tutorial-bank').addEventListener('click', () => startTutorial('bank'));
  $('rules-tutorial-quiz').addEventListener('click', () => startTutorial('quiz'));
  
  $('tutorial-close').addEventListener('click', endTutorial);
  $('tutorial-next').addEventListener('click', nextTutorialStep);
  $('tutorial-prev').addEventListener('click', prevTutorialStep);
  $('tutorial-skip').addEventListener('click', () => { endTutorial(); toast('Tutorial skipped. You can replay it anytime in the Rules section.','info'); });
  
  updateStatsDisplay();
  updateUIGameState();
  toast('Welcome! Visit Rules for interactive tutorials or start playing!','info',4000);
}

if(document.readyState==='loading') document.addEventListener('DOMContentLoaded',init); else init();
</script>
