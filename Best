  try {
    const r=await fetch('https://bible-api.com/'+encodeURIComponent(ref)+'?translation=web');
    if(!r.ok)throw new Error(); const data=await r.json(); if(!data.text)throw new Error();
    const text=data.text.replace(/[^\w\s']/g,' ').replace(/\s+/g,' ').trim();
    const wc=text.split(' ').filter(w=>w).length;
    resEl.innerHTML=`<div class="api-verse-ref">${data.reference}</div><div class="api-verse-text">${text}</div><p style="color:var(--light-gray);font-size:0.85rem;margin-top:8px;">WEB • ${wc} words</p><button class="btn btn-secondary mt-2" id="${mode}-use-api"><i class="fa-solid fa-check"></i> Use This Verse</button>`;
    $(mode+'-use-api').onclick=()=>{ state.verse={ref:data.reference,text,words:wc}; $(mode+'-verse-select').classList.add('hidden'); $(mode+'-difficulty-select').classList.remove('hidden'); $(mode+'-selected-ref').textContent=data.reference; $(mode+'-selected-text').textContent=text; const exists=state.createdVerses[mode].some(v=>v.ref===data.reference); if(!exists){state.createdVerses[mode].push({ref:data.reference,text,words:wc,date:new Date().toLocaleDateString(),difficulty:state.difficulty});saveState();} toast('Verse loaded!','success'); };
    toast('Verse fetched!','success');
  } catch(e) { resEl.innerHTML=`<p style="color:var(--error);"><i class="fa-solid fa-triangle-exclamation"></i> Could not fetch.</p>`; toast('Verse not found','error'); } finally { state.fetching=false; btn.disabled=false; }
}

function startStudy(mode) {
  state.words=state.verse.text.split(' ').filter(w=>w);
  state.roundConfigs=genRounds(mode,state.difficulty,state.words.length);
  state.totalRounds=state.roundConfigs.length; state.currentRound=1; state.xp=0; state.wordsCorrect=0; state.wordsWrong=0; state.completed=false;
  state.inGame=true; state.studySeconds=30; state.studySecondsInitial=30; state.extraStudyUses=2;
  state.helpsLeft = HELP_COUNTS[state.difficulty];
  updateExtraStudyBtn(mode); updateHelpBtn(mode); updateUIGameState();
  const sv=$(mode+'-study-verse'); sv.innerHTML = `<div class="study-phase-wrapper"><div class="study-verse-text" id="${mode}-study-text-container"></div><div class="study-reference-badge">${state.verse.ref}</div></div>`;
  const container = $(mode + '-study-text-container');
  state.words.forEach((w,i)=>{ const s=document.createElement('span'); s.className='study-word'; s.textContent=w; s.style.animation=`fadeInWord 0.4s ease ${i*0.06}s both`; container.appendChild(s); if (i < state.words.length - 1) container.appendChild(document.createTextNode(' ')); });
  $(mode+'-timer').textContent='30'; updateTimerCircle(mode,30);
  $(mode+'-verse-select').classList.add('hidden'); $(mode+'-difficulty-select').classList.add('hidden');
  $(mode+'-study-phase').classList.remove('hidden'); $(mode+'-game-phase').classList.add('hidden'); $(mode+'-results-phase').classList.add('hidden');
  state.studyTimer=setInterval(()=>{state.studySeconds--;$(mode+'-timer').textContent=state.studySeconds;updateTimerCircle(mode,state.studySeconds);if(state.studySeconds<=0){stopStudy();startRound(mode);}},1000);
  toast('Study phase started! Just start typing when ready.','info',3000);
