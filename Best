  $(mode+'-timer').style.color = sec <= 5 ? 'var(--error)' : 'var(--primary)';
}

function stopStudy() { clearInterval(state.studyTimer); state.studyTimer=null; }
function skipStudy(mode) { stopStudy(); $(mode+'-study-phase').classList.add('hidden'); startRound(mode); }

function updateExtraStudyBtn(mode) {
  const btn=$(mode+'-extra-study'); if(!btn) return;
  const count = state.extraStudyUses; const canAfford = state.xp > EXTRA_STUDY_COST;
  btn.disabled = count <= 0 || !canAfford;
  btn.innerHTML = count <= 0 ? `<i class="fa-solid fa-lock"></i> No extra time left` : !canAfford ? `<i class="fa-solid fa-clock"></i> Need >15 XP` : `<i class="fa-solid fa-clock"></i> +20s <span class="study-extra-badge">${count} left</span>`;
}

function updateHelpBtn(mode) {
  const btn = $(mode + '-help-btn'); if(!btn) return;
  const count = state.helpsLeft; const canAfford = state.stats.totalXp >= HELP_COST;
  btn.disabled = count <= 0 || !canAfford;
  btn.innerHTML = count <= 0 ? `<i class="fa-solid fa-lock"></i> No helps left` : !canAfford ? `<i class="fa-solid fa-clock"></i> Need 50 XP` : `<i class="fa-solid fa-eye"></i> Peek Verse <span class="study-extra-badge">${count} left</span>`;
}

function startRound(mode) {
  const blankCount=state.roundConfigs[state.currentRound-1];
  const isFinal=blankCount>=state.words.length;
  $(mode+'-round-num').textContent=state.currentRound; $(mode+'-total-rounds').textContent=state.totalRounds;
  updateXPHighlight(mode, state.xp); updateAccuracyDisplay(mode); updateHelpBtn(mode);
  $(mode+'-study-phase').classList.add('hidden'); $(mode+'-game-phase').classList.remove('hidden'); $(mode+'-results-phase').classList.add('hidden');
  if(mode==='fill')setupFillRound(blankCount,isFinal);
  else if(mode==='bank')setupBankRound(blankCount,isFinal);
  else setupQuizRound(blankCount,isFinal);
  if(isFinal) $(mode+'-instructions').textContent='Final Challenge: Fill the ENTIRE verse!';
  else {const msgs={fill:`Just start typing! ${blankCount} blank(s) this round.`,bank:`Drag or click words. ${blankCount} blank(s) this round.`,quiz:'Select ALL answers, then Submit.'};$(mode+'-instructions').textContent=msgs[mode];}
  $(mode+'-submit-answer').disabled=true;
}

function updateAccuracyDisplay(mode) {
  const el=$(mode+'-accuracy'); if(!el)return;
  const total=state.wordsCorrect+state.wordsWrong; if(total===0){el.textContent='—';return;}
  const acc = Math.min(100, Math.round((state.wordsCorrect / total) * 100));
  el.textContent = acc + '%'; el.style.color=acc>=80?'var(--success)':acc>=50?'#f59e0b':'var(--error)';
}

function updateXPHighlight(mode,val) { 
  const el=$(mode+'-xp'); el.textContent=val; el.style.transform = 'scale(1.15)'; el.style.color = val >= 100 ? 'var(--success)' : 'var(--error)';
  setTimeout(() => { el.style.transform = 'scale(1)'; el.style.color = 'var(--primary)'; }, 300);
}

function calculateXP(correctCount, isPerfect) { return Math.round((correctCount * 10 * XP_MULT[state.difficulty]) + (isPerfect ? 50 : 0)); }

// ==================== FILL MODE ====================
function setupFillRound(count,isFinal) {
  state.fillBlanks = selectBlanks(state.words, Math.min(count, state.words.length)).sort((a,b) => a-b);
  state.fillAnswers = new Array(state.fillBlanks.length).fill(''); state.fillActiveIdx = 0; state.fillPhase = 'filling'; 
  state.fillWrongSet = new Set(); state.fillCorrectSet = new Set(); state.fillFirstTryOk = 0; state.fillSubmitCount = 0;
  if(window.fillAutoFocusHandler) document.removeEventListener('keydown', window.fillAutoFocusHandler);
  window.fillAutoFocusHandler = (e) => {
    if(state.fillPhase !== 'filling') return;
    if(document.activeElement.tagName !== 'INPUT' && e.key.length === 1 && !e.ctrlKey && !e.metaKey && !e.altKey) {
      e.preventDefault(); focusFillBlank();
      setTimeout(() => { const inp = document.querySelector(`#fill-game-verse .blank-input[data-blank="${state.fillActiveIdx}"]`); if(inp) { inp.value = e.key; inp.dispatchEvent(new Event('input', {bubbles: true})); } }, 10);
    }
  };
  document.addEventListener('keydown', window.fillAutoFocusHandler); renderFillVerse(); focusFillBlank();
}

function renderFillVerse() {
  const el=$('fill-game-verse'); el.innerHTML=''; const contentWrapper = document.createElement('div'); contentWrapper.className = 'verse-content';
  state.words.forEach((word,wi)=>{
    const chronIndex = state.fillBlanks.indexOf(wi);
    if(chronIndex === -1) { const s=document.createElement('span'); s.className='verse-word'; s.textContent=word; contentWrapper.appendChild(s); contentWrapper.appendChild(document.createTextNode(' ')); } 
    else {
      const bc=document.createElement('span'); bc.className='blank-container';
      if(state.fillPhase==='result') { const s=document.createElement('span'); s.className='blank-input correct'; s.textContent=state.words[wi]; s.style.pointerEvents='none'; bc.appendChild(s); } 
      else {
        const inp=document.createElement('input'); inp.type='text'; inp.className='blank-input'; inp.dataset.blank=chronIndex; inp.value=state.fillAnswers[chronIndex]||''; inp.placeholder='___'; inp.autocomplete='off'; inp.spellcheck=false;
        if (state.fillPhase === 'fixing') { if (state.fillWrongSet.has(chronIndex)) { inp.classList.add('incorrect'); } else if (state.fillCorrectSet.has(chronIndex)) { inp.classList.add('correct'); } else { inp.classList.add('filled'); } } 
        else { if (inp.value) inp.classList.add('filled'); }
        inp.addEventListener('input', e => { const v=e.target.value.trim(); state.fillAnswers[chronIndex]=v; e.target.classList.toggle('filled',!!v); checkFillComplete(); });
        inp.addEventListener('keydown', e => {
          if(e.key==='Enter' || e.key==='Tab') { e.preventDefault(); if(!state.fillAnswers[chronIndex]) return; if(state.fillAnswers.every(a => a.trim() !== '')) submitFill(); else { let nextIdx = -1; for(let i = 0; i < state.fillBlanks.length; i++) { if(!state.fillAnswers[i]) { nextIdx = i; break; } } if(nextIdx !== -1) { state.fillActiveIdx = nextIdx; renderFillVerse(); focusFillBlank(nextIdx); } else submitFill(); } }
        });
        inp.addEventListener('click', (e) => { e.stopPropagation(); state.fillActiveIdx = chronIndex; renderFillVerse(); focusFillBlank(chronIndex); });
        bc.appendChild(inp);
      }
      contentWrapper.appendChild(bc); contentWrapper.appendChild(document.createTextNode(' '));
    }
  });
  el.appendChild(contentWrapper); const ref = document.createElement('div'); ref.className = 'verse-ref-bottom'; ref.textContent = state.verse.ref; el.appendChild(ref);
}

function focusFillBlank(idx) { const target = idx !== undefined ? idx : state.fillActiveIdx; setTimeout(() => { const inp=document.querySelector(`#fill-game-verse .blank-input[data-blank="${target}"]`); if(inp) { inp.focus(); inp.select(); } }, 50); }
function checkFillComplete() { $('fill-submit-answer').disabled=!state.fillAnswers.every(a=>a.trim()!==''); }

function submitFill() {
  state.fillSubmitCount++; let allOk=true; state.fillWrongSet.clear(); state.fillCorrectSet.clear(); let roundCorrectCount = 0; let roundWrongCount = 0;
  state.fillBlanks.forEach((wi,bi)=>{ const correct=state.fillAnswers[bi]?.toLowerCase().trim()===state.words[wi].toLowerCase(); if(correct) { state.fillCorrectSet.add(bi); if(state.fillSubmitCount===1) state.fillFirstTryOk++; roundCorrectCount++; } else { state.fillWrongSet.add(bi); allOk=false; roundWrongCount++; } });
  state.wordsCorrect += roundCorrectCount; state.wordsWrong += roundWrongCount;
  const roundAcc = state.fillBlanks.length > 0 ? Math.min(100, Math.round((state.fillBlanks.length - state.fillWrongSet.size) / state.fillBlanks.length * 100)) : 0;
  const totalAttempts = state.wordsCorrect + state.wordsWrong; const verseAcc = totalAttempts > 0 ? Math.min(100, Math.round((state.wordsCorrect / totalAttempts) * 100)) : 0;
  if(allOk) {
    let roundXP = calculateXP(state.fillFirstTryOk, true); state.xp += roundXP; updateXPHighlight('fill', state.xp);
    $('fill-round-xp').textContent = roundXP; $('fill-total-xp').textContent = state.xp; $('fill-round-accuracy').textContent = roundAcc + '%'; $('fill-verse-accuracy').textContent = verseAcc + '%';
    $('fill-results-message').textContent = `Round: ${roundAcc}% | Verse: ${verseAcc}%! +${roundXP} XP earned!`;
    state.fillPhase='result'; renderFillVerse(); $('fill-submit-answer').disabled=true;
    setTimeout(()=>{$('fill-game-phase').classList.add('hidden');$('fill-results-phase').classList.remove('hidden');if(state.currentRound===state.totalRounds)confetti();},800);
  } else { state.fillPhase='fixing'; for(let i=0; i<state.fillBlanks.length; i++) { if(state.fillWrongSet.has(i)) { state.fillActiveIdx = i; break; } } renderFillVerse(); focusFillBlank(); toast(`Fix the ${state.fillWrongSet.size} incorrect word(s)!`,'error',3000); }
}

// ==================== BANK MODE ====================
function setupBankRound(count,isFinal) {
  if(isFinal) state.bankBlanks=state.words.map((_,i)=>i); else state.bankBlanks=selectBlanks(state.words,Math.min(count,state.words.length));
  state.bankAnswers={}; state.bankPool = [...state.words];
  if(state.difficulty==='hard') { const extraCount = Math.ceil(state.words.length * 0.5); state.bankPool = state.bankPool.concat(shuffle([...state.words]).slice(0, extraCount)); }
  state.bankPool = shuffle(state.bankPool); renderBankVerse(); renderBankWordBank();
}

function renderBankVerse() {
  const el=$('bank-game-verse'); const contentWrapper = document.createElement('div'); contentWrapper.className = 'verse-content';
  state.words.forEach((word,wi)=>{
    if(state.bankBlanks.includes(wi)) {
      const slot=document.createElement('span'); slot.className='blank-slot'; slot.dataset.index=wi;
      if(state.bankAnswers[wi]!==undefined) { slot.textContent=state.bankAnswers[wi]; slot.classList.add('filled'); } else { slot.textContent='\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0'; }
      slot.onclick=()=>{ if(state.bankAnswers[wi]!==undefined) { delete state.bankAnswers[wi]; renderBankVerse(); renderBankWordBank(); checkBankComplete(); } };
      slot.ondragover=e=>{e.preventDefault();slot.style.borderBottomColor='var(--primary)';}; slot.ondragleave=()=>{slot.style.borderBottomColor='';}; slot.ondrop=e=>{e.preventDefault();placeBankWord(wi,e.dataTransfer.getData('text'));};
      contentWrapper.appendChild(slot);
    } else { const s=document.createElement('span');s.className='verse-word';s.textContent=word; contentWrapper.appendChild(s); }
    contentWrapper.appendChild(document.createTextNode(' '));
  });
  el.innerHTML = ''; el.appendChild(contentWrapper); const ref = document.createElement('div'); ref.className = 'verse-ref-bottom'; ref.textContent = state.verse.ref; el.appendChild(ref);
}

function renderBankWordBank() {
  const el = $('bank-word-bank'); el.innerHTML = ''; const bankWords = state.bankPool || [];
  const placedCounts = {}; Object.values(state.bankAnswers).forEach(w => { placedCounts[w] = (placedCounts[w] || 0) + 1; });
  bankWords.forEach((word, idx) => {
    const isUsed = (placedCounts[word] || 0) > 0; if (isUsed) placedCounts[word]--;
    const chip = document.createElement('div'); chip.className = 'word-chip' + (isUsed ? ' used' : ''); chip.textContent = word; chip.draggable = !isUsed;
    chip.ondragstart = e => { if(isUsed){e.preventDefault();return;} e.dataTransfer.setData('text', word); };
    chip.onclick = () => { if(isUsed) return; const sortedBlanks = [...state.bankBlanks].sort((a, b) => a - b); const nextBlank = sortedBlanks.find(wi => state.bankAnswers[wi] === undefined); if (nextBlank !== undefined) placeBankWord(nextBlank, word); };
    el.appendChild(chip);
  });
}

function placeBankWord(wi, word) { state.bankAnswers[wi] = word; renderBankVerse(); renderBankWordBank(); checkBankComplete(); }
function checkBankComplete(){$('bank-submit-answer').disabled=!state.bankBlanks.every(wi=>state.bankAnswers[wi]!==undefined);}

function submitBank() {
  let roundCorrect=0, roundWrong=0, allOk=true;
  state.bankBlanks.forEach(wi=>{const c=state.bankAnswers[wi]?.toLowerCase()===state.words[wi].toLowerCase();c?roundCorrect++:roundWrong++;});
  state.wordsCorrect += roundCorrect; state.wordsWrong += roundWrong;
  if(allOk){
    const roundXP=calculateXP(roundCorrect,true); state.xp+=roundXP; updateXPHighlight('bank',state.xp);
    $('bank-round-xp').textContent=roundXP; $('bank-total-xp').textContent=state.xp; 
    const roundAcc = 100; const totalAttempts = state.wordsCorrect + state.wordsWrong; const verseAcc = totalAttempts > 0 ? Math.min(100, Math.round((state.wordsCorrect / totalAttempts) * 100)) : 0;
    $('bank-round-accuracy').textContent=roundAcc+'%'; $('bank-verse-accuracy').textContent=verseAcc+'%';
    $('bank-results-message').textContent=`Round: ${roundAcc}% | Verse: ${verseAcc}% | +${roundXP} XP earned!`;
    setTimeout(()=>{$('bank-game-phase').classList.add('hidden');$('bank-results-phase').classList.remove('hidden');if(state.currentRound===state.totalRounds)confetti();},500);
  } else {
    state.bankBlanks.forEach(wi=>{const s=document.querySelector(`.blank-slot[data-index="${wi}"]`);if(s)s.classList.add(state.bankAnswers[wi]?.toLowerCase()===state.words[wi].toLowerCase()?'correct':'incorrect');});
    setTimeout(()=>{state.bankBlanks.forEach(wi=>{if(state.bankAnswers[wi]?.toLowerCase()!==state.words[wi].toLowerCase())delete state.bankAnswers[wi];});renderBankVerse();renderBankWordBank();checkBankComplete();},1500);
    toast(`${roundWrong} incorrect. Fix!`,'error',3000);
  }
}

// ==================== QUIZ MODE ====================
function setupQuizRound(count,isFinal) {
  if(isFinal) state.quizBlanks=state.words.map((_,i)=>i); else state.quizBlanks=selectBlanks(state.words,Math.min(count,state.words.length));
  
  state.quizBlanks.sort((a, b) => a - b); 
  state.quizAnswers = {}; 
  state.quizChecked = false;
  
  const allVerseWords = new Set(); 
  BIBLE_VERSES.forEach(v => v.text.split(' ').forEach(w => allVerseWords.add(w.toLowerCase())));
  const allVerseWordsList = [...allVerseWords]; 
  const currentVerseWords = [...new Set(state.words.map(w => w.toLowerCase()))];
  const targetDistractors = state.difficulty === 'easy' ? 3 : state.difficulty === 'medium' ? 5 : 7;
  
  state.quizQuestions = state.quizBlanks.map((wi, qi) => {
    const correct = state.words[wi]; 
    const correctLower = correct.toLowerCase(); 
    const correctLen = correct.length; 
    const distractors = [];
    
    const addDistractor = (word) => { 
      const wl = word.toLowerCase(); 
      if(wl === correctLower) return false; 
      if(distractors.map(d => d.toLowerCase()).includes(wl)) return false; 
      if(word.length < 2) return false; 
      distractors.push(word); 
      return true; 
    };
    
    const sameVerse = currentVerseWords.filter(w => w !== correctLower && w.length >= 2);
    const otherVerse = allVerseWordsList.filter(w => w !== correctLower && !currentVerseWords.includes(w) && w.length >= 2);
    
    let pool = [];
    if(state.difficulty === 'easy') pool = shuffle([...sameVerse, ...otherVerse]).filter(w => Math.abs(w.length - correctLen) >= 1);
    else if(state.difficulty === 'medium') { 
      const medSame = sameVerse.filter(w => Math.abs(w.length - correctLen) <= 1); 
      const medOther = otherVerse.filter(w => Math.abs(w.length - correctLen) <= 2); 
      pool = shuffle([...medSame, ...medOther]); 
    }
    else { 
      const hardSame = sameVerse.filter(w => Math.abs(w.length - correctLen) <= 1); 
      const hardOther = otherVerse.filter(w => Math.abs(w.length - correctLen) <= 1); 
      const sameLen = allVerseWordsList.filter(w => w !== correctLower && w.length === correctLen); 
      pool = shuffle([...hardSame, ...hardOther, ...sameLen]); 
    }
    
    for(const word of pool) { if(distractors.length >= targetDistractors) break; addDistractor(word); }
    const fallback = otherVerse.filter(w => !distractors.includes(w));
    while(distractors.length < targetDistractors && fallback.length > 0) { 
      addDistractor(fallback.splice(Math.floor(Math.random() * fallback.length), 1)[0]); 
    }
    while(distractors.length < targetDistractors) { 
      const fb = allVerseWordsList[Math.floor(Math.random() * allVerseWordsList.length)]; 
      addDistractor(fb); 
    }
    
    return {
      qi, 
      wi, 
      correct, 
      options: shuffle([correct, ...distractors.slice(0, targetDistractors)]),
      answeredCorrectly: false
    };
  });
  renderQuizVerse(); 
  renderQuizQuestions();
}

function renderQuizVerse() {
  const el=$('quiz-game-verse'); const contentWrapper = document.createElement('div'); contentWrapper.className = 'verse-content';
  state.words.forEach((word,wi)=>{
    const blankNum = state.quizBlanks.indexOf(wi);
    if(blankNum !== -1){
      const bc=document.createElement('span');bc.className='blank-container';
      const num=document.createElement('sup'); num.style.cssText='color:var(--primary);font-weight:800;font-size:0.7em;margin-right:2px;'; num.textContent = blankNum + 1; bc.appendChild(num);
      const blank=document.createElement('span'); blank.className='blank-slot'; blank.id='quiz-blank-'+blankNum; blank.textContent='\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0'; blank.style.borderBottomColor='var(--primary)'; blank.style.borderBottomStyle='dashed'; bc.appendChild(blank); contentWrapper.appendChild(bc);
    } else { const s=document.createElement('span');s.className='verse-word';s.textContent=word; contentWrapper.appendChild(s); }
    contentWrapper.appendChild(document.createTextNode(' '));
  });
  el.innerHTML = ''; el.appendChild(contentWrapper); const ref = document.createElement('div'); ref.className = 'verse-ref-bottom'; ref.textContent = state.verse.ref; el.appendChild(ref);
}

function renderQuizQuestions() {
  const container = $('quiz-questions-container'); 
  container.innerHTML = '';
  
  state.quizQuestions.forEach(q => {
    const block = document.createElement('div');
    block.className = 'question-block';
    
    let optionsHTML = '';
    if(q.answeredCorrectly) {
      optionsHTML = `<div style="text-align:center;padding:12px;color:var(--success);font-weight:600;">
        <i class="fa-solid fa-check-circle"></i> Correct!
      </div>`;
    } else {
      optionsHTML = q.options.map((opt, oi) => 
        `<div class="mc-option" data-qi="${q.qi}" data-oi="${oi}">${opt}</div>`
      ).join('');
    }
    
    block.innerHTML = `
      <div class="question-title">
        <span class="question-number">${q.qi+1}</span>
        Blank #${q.qi+1}
      </div>
      <div class="mc-options" id="quiz-opts-${q.qi}">
        ${optionsHTML}
      </div>
    `;
    container.appendChild(block);
    
    if(!q.answeredCorrectly) {
      block.querySelectorAll('.mc-option').forEach(opt => {
        opt.onclick = () => {
          if(state.quizChecked) return;
          const qi = parseInt(opt.dataset.qi);
          state.quizAnswers[qi] = q.options[parseInt(opt.dataset.oi)];
          
          block.querySelectorAll('.mc-option').forEach(o => o.classList.remove('selected'));
          opt.classList.add('selected');
          
          const blank = $('quiz-blank-' + qi);
          if(blank) {
            blank.textContent = state.quizAnswers[qi];
            blank.style.borderBottomStyle = 'solid';
            blank.style.borderBottomColor = 'var(--primary)';
            blank.style.color = 'var(--primary)';
            blank.style.fontWeight = '600';
          }
          checkQuizComplete();
        };
      });
    }
  });
}

function checkQuizComplete() {
  const unanswered = state.quizQuestions.filter(q => !q.answeredCorrectly);
  const allAnswered = unanswered.every(q => state.quizAnswers[q.qi] !== undefined);
  $('quiz-submit-answer').disabled = !allAnswered;
}

function submitQuiz() {
  if(state.quizChecked) return;
  state.quizChecked = true;
  
  state.quizQuestions.forEach(q => {
    const qi = q.qi;
    if(q.answeredCorrectly) return;
    
    const userAnswer = state.quizAnswers[qi]?.toLowerCase();
    const correctAnswer = q.correct.toLowerCase();
    
    if(userAnswer === correctAnswer) {
      state.wordsCorrect++;
      q.answeredCorrectly = true;
    } else {
      state.wordsWrong++;
      delete state.quizAnswers[qi];
    }
  });
  
  updateAccuracyDisplay('quiz');
  
  state.quizQuestions.forEach(q => {
    const qi = q.qi;
    const opts = document.querySelectorAll(`#quiz-opts-${qi} .mc-option`);
    const blank = $('quiz-blank-' + qi);
    
    if(q.answeredCorrectly) {
      opts.forEach(o => {
        o.classList.add('disabled');
        if(q.options[parseInt(o.dataset.oi)].toLowerCase() === q.correct.toLowerCase()) {
          o.classList.add('correct');
        }
      });
      if(blank) {
        blank.textContent = q.correct;
        blank.style.borderBottomStyle = 'solid';
        blank.style.borderBottomColor = 'var(--success)';
        blank.style.color = 'var(--success)';
        blank.style.fontWeight = '700';
      }
    } else {
      opts.forEach(o => {
        o.classList.add('disabled');
        if(o.classList.contains('selected')) {
          o.classList.add('incorrect');
        }
      });
      if(blank) {
        blank.textContent = '\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0\u00a0';
        blank.style.borderBottomColor = 'var(--error)';
        blank.style.borderBottomStyle = 'dashed';
        blank.style.animation = 'shake 0.3s ease';
        setTimeout(() => { blank.style.animation = ''; }, 300);
      }
    }
  });
  
  const allCorrect = state.quizQuestions.every(q => q.answeredCorrectly);
  
  if(allCorrect) {
    const totalBlanks = state.quizQuestions.length;
    const roundXP = calculateXP(totalBlanks, true);
    state.xp += roundXP;
    updateXPHighlight('quiz', state.xp);
    
    $('quiz-round-xp').textContent = roundXP;
    $('quiz-total-xp').textContent = state.xp;
    
    const totalAttempts = state.wordsCorrect + state.wordsWrong;
    const verseAcc = totalAttempts > 0 ? Math.min(100, Math.round((state.wordsCorrect / totalAttempts) * 100)) : 0;
    
    $('quiz-round-accuracy').textContent = '100%';
    $('quiz-verse-accuracy').textContent = verseAcc + '%';
    $('quiz-results-message').textContent = `Round: 100% | Verse: ${verseAcc}% | +${roundXP} XP earned!`;
    
    setTimeout(() => {
      $('quiz-game-phase').classList.add('hidden');
      $('quiz-results-phase').classList.remove('hidden');
      if(state.currentRound === state.totalRounds) confetti();
    }, 800);
  } else {
    state.quizChecked = false;
    
    state.quizQuestions.forEach(q => {
      if(!q.answeredCorrectly) {
        const opts = document.querySelectorAll(`#quiz-opts-${q.qi} .mc-option`);
        opts.forEach(o => {
          o.classList.remove('disabled', 'selected', 'correct', 'incorrect');
          o.style.pointerEvents = '';
        });
      }
    });
    
    checkQuizComplete();
    
    const remaining = state.quizQuestions.filter(q => !q.answeredCorrectly).length;
    toast(`${remaining} blank(s) still need the right answer. Keep guessing!`, 'info', 3000);
  }
}

// ==================== HELP FUNCTIONALITY ====================
function activateHelp(mode) {
  const btn = $(mode + '-help-btn');
  if (btn.disabled) { toast(state.helpsLeft <= 0 ? 'No helps left!' : `Need 50 XP! You have ${state.stats.totalXp}.`, 'error'); return; }
  state.stats.totalXp = Math.max(0, state.stats.totalXp - HELP_COST); state.helpsLeft--; updateHelpBtn(mode);
  const el = $(mode + '-game-verse'); const originalContent = el.innerHTML;
  el.innerHTML = `<div class="study-phase-wrapper"><div class="study-verse-text">${state.verse.text}</div><div class="study-reference-badge">${state.verse.ref}</div></div>`;
  toast('Help used! Verse shown for 5 seconds.', 'info', 2000);
  setTimeout(() => { el.innerHTML = originalContent; }, 5000);
}

// ==================== NEXT ROUND & COMPLETION ====================
function nextRound(mode) {
  if (state.completed) return; state.currentRound++;
  if(state.currentRound > state.totalRounds){
    state.completed = true;
    const acc = (state.wordsCorrect + state.wordsWrong > 0) ? Math.min(100, Math.round((state.wordsCorrect / (state.wordsCorrect + state.wordsWrong)) * 100)) : 100;
    state.memorizedVersesByMode[mode][state.verse.ref] = { xp: state.xp, accuracy: acc, rounds: state.totalRounds, score: state.xp };
    const streakBonus = Math.min(state.stats.currentStreak * 5, 50);
    state.stats.totalXp += state.xp + streakBonus;
    state.stats.gamesPlayed++; state.stats.versesMastered++; state.stats.totalRight += state.wordsCorrect; state.stats.totalAttempted += state.wordsWrong + state.wordsCorrect;
    state.stats.currentStreak++; if(state.stats.currentStreak > state.stats.maxStreak) state.stats.maxStreak = state.stats.currentStreak;
    updateStatsDisplay(); saveState();
    $(mode+'-results-phase').classList.add('hidden'); $(mode+'-game-phase').classList.add('hidden');
    let msg = `Mastered ${state.verse.ref}! Session XP: ${state.xp} (Added to Total!)`;
    if(streakBonus > 0) msg += `\n🔥 Streak Bonus: +${streakBonus} XP`;
    msg += `\n💰 Total XP: ${state.stats.totalXp} | Accuracy: ${acc}%`;
    $(mode+'-results-message').textContent=msg; $(mode+'-round-xp').textContent=state.xp; $(mode+'-round-accuracy').textContent=acc+'%'; $(mode+'-total-xp').textContent=state.stats.totalXp;
    if(!state.createdVerses[mode].some(v=>v.ref===state.verse.ref)){state.createdVerses[mode].push({ref:state.verse.ref,text:state.verse.text,words:state.words.length,date:new Date().toLocaleDateString(),difficulty:state.difficulty});saveState();}
    state.inGame=false; updateUIGameState(); $(mode+'-results-phase').classList.remove('hidden'); confetti();
    toast('Verse mastered! Stats updated! 🎉','success',5000);
    $(mode+'-next-round').innerHTML='<i class="fa-solid fa-house"></i> Back to Home';
    $(mode+'-next-round').onclick=()=>{state.inGame=false;showScreen('home-screen');};
    return;
  }
  $(mode+'-results-phase').classList.add('hidden'); startRound(mode);
}

